#!/usr/bin/env bash
# Pre-commit hook: regenerate artifacts and stage them if they changed.
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"

# Only run if source files that affect generation are staged
PATTERN='scripts/|SKILL\.md|package\.json|\.claude-plugin/marketplace\.json'
if ! git diff --cached --name-only | grep -qE "$PATTERN"; then
  exit 0
fi

"$ROOT_DIR/scripts/publish.sh" >/dev/null 2>&1

# Stage any generated files that changed
GENERATED_FILES=(
  "agents/AGENTS.md"
  "README.md"
  ".cursor-plugin/plugin.json"
  ".mcp.json"
  ".claude-plugin/plugin.json"
  ".claude-plugin/marketplace.json"
  "gemini-extension.json"
)

for f in "${GENERATED_FILES[@]}"; do
  if [[ -f "$ROOT_DIR/$f" ]]; then
    git add "$ROOT_DIR/$f"
  fi
done
